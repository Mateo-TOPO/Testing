# ============================================================
# LAIMS Landing Page – Umgebungsvariablen
# ============================================================
# Diese Datei dient als Vorlage. Kopiere sie nach .env.local
# und trage deine lokalen Werte ein. .env.local wird von Vite
# automatisch geladen und darf NICHT ins Git-Repository.
# ============================================================

# Base-URL des LAIMS-Backend-API.
# Wird serverseitig im Hono-Proxy genutzt (/api/public/*).
# Lokal: der API-Dev-Server (z.B. laims-api auf Port 3002).
# Produktion: die öffentliche API-Domain.
VITE_API_BASE_URL=http://localhost:3002

# Base-URL der LAIMS-Webapp (das eigentliche ERP-Frontend).
# Wird für folgende Links verwendet:
#   - "Anmelden"-Button in der Navigation  → {URL}/login
#   - "Login"-Link im Footer               → {URL}/login
#   - Paket-Buttons "X Tage kostenlos"     → {URL}/register?package=<slug>
#     (jährlich: {URL}/register?package=<slug>&interval=yearly)
# Lokal: der App-Dev-Server (z.B. laims-app auf Port 3001).
# Produktion: die öffentliche App-Domain (z.B. https://app.laims.de).
VITE_APP_BASE_URL=http://localhost:3003

# ============================================================
# E-Mail-Versand: Enterprise-Anfragen (via SMTP / nodemailer)
# ============================================================
# Lokal (.env.local): Variablen ohne VITE_-Präfix – Vite lädt sie
#   automatisch in process.env (für den Hono-Dev-Server).
# Produktion (Vercel): im Vercel Dashboard unter
#   Settings → Environment Variables → Production eintragen.
#
SMTP_HOST=mail.example.com
# 587 = STARTTLS (empfohlen), 465 = SSL/TLS
SMTP_PORT=587
# true bei Port 465, false bei Port 587
SMTP_SECURE=false
SMTP_USER=anfragen@example.com
SMTP_PASS=ihr-smtp-passwort
# Empfänger der Enterprise-Anfragen
CONTACT_EMAIL=info@laims.de
# Optional: Absenderanzeige (Standard: LAIMS <SMTP_USER>)
EMAIL_FROM=LAIMS Anfragen <anfragen@example.com>

# ============================================================
# Spam-Schutz: Cloudflare Turnstile (optional, empfohlen)
# ============================================================
# Site-Key + Secret-Key aus dem Cloudflare-Dashboard:
#   https://dash.cloudflare.com → Turnstile → Add site
# Wenn beide Werte LEER sind, wird Turnstile sowohl im HTML als auch
# serverseitig komplett übersprungen — das Formular läuft normal weiter
# (Honeypot, Min-Form-Dauer, IP-Rate-Limit + E-Mail-MX-Check schützen).
#
# Cloudflare-Test-Keys (immer „pass", ohne echte Challenge) für lokales Dev:
#   TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
