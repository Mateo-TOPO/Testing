{
  "name": "laims",
  "version": "1.0.0",
  "type": "module",
  "description": "LAIMS – ERP-System für die Textilveredelungsbranche",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --local --ip 0.0.0.0 --port 3000",
    "build:css": "tailwindcss -i src/styles/input.css -o public/static/css/tailwind.css --minify",
    "build:og": "tsx scripts/generate-og.ts",
    "build:html": "tsx scripts/generate.tsx",
    "build": "npm run build:css && npm run build:og && npm run build:html",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name laims",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "db:migrate:auth": "wrangler d1 migrations apply laims-auth --local",
    "db:migrate:tenant1": "wrangler d1 migrations apply laims-tenant-demo-textilveredlung --local",
    "db:migrate:tenant2": "wrangler d1 migrations apply laims-tenant-zweite-werkstatt --local",
    "db:migrate:all": "npm run db:migrate:auth && npm run db:migrate:tenant1 && npm run db:migrate:tenant2",
    "db:seed:tenant1": "wrangler d1 execute laims-tenant-demo-textilveredlung --local --file=./seed.sql",
    "db:seed:auth": "wrangler d1 execute laims-auth --local --file=./seed-auth.sql",
    "db:seed:all": "npm run db:seed:auth && npm run db:seed:tenant1",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:all && npm run db:seed:all",
    "db:console:auth": "wrangler d1 execute laims-auth --local",
    "db:console:tenant1": "wrangler d1 execute laims-tenant-demo-textilveredlung --local",
    "db:console:tenant2": "wrangler d1 execute laims-tenant-zweite-werkstatt --local"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "hono": "^4.12.6",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.18.2",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.4",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
